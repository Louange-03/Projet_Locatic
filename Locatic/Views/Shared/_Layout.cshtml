<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Locatic</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Locatic.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-locatic">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">🚗</span> Locatic
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="vehicules">Nos véhicules</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle admin-link" href="#" data-bs-toggle="dropdown">
                                Gestion
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Brand" asp-action="Index">Marques</a></li>
                                <li><a class="dropdown-item" asp-controller="Modele" asp-action="Index">Modèles</a></li>
                                <li><a class="dropdown-item" asp-controller="Car" asp-action="Index">Voitures</a></li>
                                <li><a class="dropdown-item" asp-controller="Client" asp-action="Index">Clients</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Reservation" asp-action="Index">Réservations</a></li>
                                <li><a class="dropdown-item" asp-controller="Reservation" asp-action="Create">Nouvelle réservation (admin)</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (ViewData["FullWidth"] as bool? == true)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container page-container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="site-footer">
        <div class="container">
            <div class="footer-content">
                <div>
                    <strong>Locatic</strong>
                    <p class="mb-0">Votre partenaire location de voitures</p>
                </div>
                <div class="footer-links">
                    <a asp-controller="Home" asp-action="Index">Accueil</a>
                    <a asp-controller="Home" asp-action="Privacy">Confidentialité</a>
                </div>
            </div>
            <div class="footer-bottom">
                &copy; 2026 - Locatic
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
